# Test image for the SDUI contract repository.
#
# This repository is the one place in Mosaic that genuinely needs **two**
# toolchains in the same process tree, which is why it is the only one with a
# Dockerfile of its own rather than a stock image in its compose file. The
# schema is the single source of truth and the bindings are output: the drift
# guard regenerates Go *and* TypeScript from schema/sdui.schema.json and fails
# if the committed files moved. That means one command needs `go`, `gofmt`,
# `node` and `npx` at once — a host that has three of the four produces a
# check that passes by not running.
#
# Node is copied from the official image rather than installed from a
# distribution repository: bookworm ships a Node too old for the generators,
# and the node and golang images share a Debian base, so the binary matches the
# glibc underneath it.
FROM node:22-bookworm-slim AS node

FROM golang:1.25-bookworm

COPY --from=node /usr/local/bin/node /usr/local/bin/node
COPY --from=node /usr/local/lib/node_modules /usr/local/lib/node_modules
RUN set -eux; \
    ln -s /usr/local/lib/node_modules/npm/bin/npm-cli.js /usr/local/bin/npm; \
    ln -s /usr/local/lib/node_modules/npm/bin/npx-cli.js /usr/local/bin/npx; \
    node --version; \
    npm --version

# The drift guard's verdict is `git diff`, and git refuses to read a
# bind-mounted repository owned by a different uid than the one running it —
# it reports dubious ownership and exits non-zero, which looks exactly like
# stale bindings. This is a single-purpose test container, so the broad rule is
# the honest one.
RUN git config --global --add safe.directory '*'

# The bind-mounted source carries a .git the container has no business
# stat-ing, and Go fails the build on its ownership rather than degrading.
ENV GOFLAGS=-buildvcs=false

WORKDIR /src/sdui

{
  "name": "@mosaic-media/sdui",
  "version": "0.8.0",
  "description": "Mosaic Server-Driven-UI contract: schema-generated types, the standard component-definition library, design tokens, and the generated protobuf session transport bindings.",
  "license": "Apache-2.0",
  "type": "module",
  "types": "./ts/contract.gen.ts",
  "exports": {
    ".": "./ts/contract.gen.ts",
    "./ui": "./ts/ui.ts",
    "./session": "./gen-ts/mosaic/session/v1/session_pb.ts",
    "./sdui-pb": "./gen-ts/mosaic/sdui/v1/sdui_pb.ts",
    "./definitions/*": "./definitions/*",
    "./tokens.json": "./tokens/tokens.json",
    "./schema.json": "./schema/sdui.schema.json"
  },
  "files": [
    "ts/contract.gen.ts",
    "ts/ui.ts",
    "ts/ui_runtime.ts",
    "gen-ts",
    "definitions",
    "tokens",
    "schema",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "generate": "bash scripts/generate.sh",
    "check:generated": "bash scripts/check-generated.sh",
    "typecheck": "tsc --noEmit --strict --module esnext --moduleResolution bundler --target es2022 --lib es2022,dom ts/contract.gen.ts ts/ui.ts gen-ts/mosaic/session/v1/session_pb.ts gen-ts/mosaic/sdui/v1/sdui_pb.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mosaic-media/sdui.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "keywords": [
    "mosaic",
    "sdui",
    "server-driven-ui",
    "json-schema",
    "design-tokens",
    "connect",
    "protobuf"
  ],
  "dependencies": {
    "@bufbuild/protobuf": "^2.13.0"
  },
  "devDependencies": {
    "@bufbuild/protoc-gen-es": "^2.13.0",
    "typescript": "^5.9.3"
  }
}

{
  "name": "@mosaic-media/sdui",
  "version": "0.2.0",
  "description": "Mosaic Server-Driven-UI contract: schema-generated types, the standard component-definition library, and design tokens.",
  "license": "Apache-2.0",
  "type": "module",
  "types": "./ts/contract.gen.ts",
  "exports": {
    ".": "./ts/contract.gen.ts",
    "./definitions/*": "./definitions/*",
    "./tokens.json": "./tokens/tokens.json",
    "./schema.json": "./schema/sdui.schema.json"
  },
  "files": [
    "ts/contract.gen.ts",
    "definitions",
    "tokens",
    "schema",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "generate": "bash scripts/generate.sh",
    "check:generated": "bash scripts/check-generated.sh",
    "typecheck": "tsc --noEmit --strict ts/contract.gen.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mosaic-media/sdui.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "keywords": [
    "mosaic",
    "sdui",
    "server-driven-ui",
    "json-schema",
    "design-tokens"
  ],
  "devDependencies": {
    "@bufbuild/protoc-gen-es": "^2.13.0",
    "typescript": "^5.9.3",
    "@bufbuild/protobuf": "^2.13.0"
  }
}
